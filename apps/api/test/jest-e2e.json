{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@jenosize/adapters$": "<rootDir>/../../../packages/adapters/src",
    "^@jenosize/shared$": "<rootDir>/../../../packages/shared/src"
  },
  "globals": {
    "ts-jest": {
      "tsconfig": "<rootDir>/../tsconfig.json"
    }
  }
}
